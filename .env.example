# ============================================================
# Konfiguration des persönlichen Finanzberater-Chatbots
# Kopiere diese Datei nach `.env` und trage deine Werte ein.
# (Key-Management-Pattern übernommen aus chatbot-pydanticai-template)
# ============================================================

# --- Variante A: Provider direkt (Standard) ---
# API-Key des Modell-Providers, z. B. OpenAI oder Anthropic.
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Modell-Kennung im pydantic-ai-Format "<provider>:<modell>".
# Beispiele: openai:gpt-4o-mini, openai:gpt-4o, anthropic:claude-sonnet-4-5
# ADVISOR_MODEL=openai:gpt-4o-mini

# --- Variante B: LiteLLM-Proxy (optional) ---
# Setze USE_LITELLM=1 (oder LITELLM_SERVER_URL + LITELLM_API_KEY),
# um Anfragen über einen laufenden LiteLLM-Server zu routen.
# USE_LITELLM=1
# LITELLM_SERVER_URL=http://localhost:4000/v1
# LITELLM_API_KEY=
# LITELLM_MODEL=openai/gpt-4o-mini

# --- Persistenz (optional) ---
# Pfad der SQLite-Datei für die Nutzerprofile (überlebt Server-Neustarts).
# Standard: advisor_sessions.db im Arbeitsverzeichnis.
# ADVISOR_DB_PATH=advisor_sessions.db

# --- Feineinstellung der Modellaufrufe (optional) ---
# Reasoning-Aufwand für Reasoning-Modelle: none|minimal|low|medium|high|xhigh|max.
# Standard "low" = schnelle Antworten in der Profilierung. "medium" liefert
# gründlichere Recherche/Strategie, dauert aber länger. Wird nur an
# OpenAI-/gpt-oss-Modelle gesendet, andere Backends ignorieren den Parameter.
# ADVISOR_REASONING_EFFORT=low

# Timeout je Modellanfrage in Sekunden (Standard 120) – verhindert, dass die
# Chat-UI bei einer hängenden Anfrage dauerhaft blockiert.
# ADVISOR_REQUEST_TIMEOUT_S=120

# Token-Limit je Modellantwort (Standard 6000). Genug Raum für Reasoning und
# Tool-Aufrufe; zu klein gewählt werden Tool-Argumente mitten im JSON
# abgeschnitten.
# ADVISOR_MAX_TOKENS=6000
